
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
        

// Example User model
model User {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String   @unique
  password     String   
  company      String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  responses    AuditResponse[]
  evaluations  AiEvaluation[]
  @@map("users")
}

model Question {
  id            Int     @id @default(autoincrement())
  standardName  String? @db.VarChar(50)  // ISO 27001, NIST
  category      String? @db.VarChar(100) // Access Control, Network Security, etc.
  clauseNumber  String? @db.VarChar(20)
  questionText  String  @db.Text         // Maps to TEXT in PostgreSQL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditResponses AuditResponse[]
  
  @@map("questions") // Maps the model to the existing database table name
}

model AuditResponse {
  id          Int      @id @default(autoincrement())
  userId      Int      // Links to the User model
  questionId  Int      // Links to the Question model
  answer      Boolean  // True for Yes, False for No
  comment     String?  @db.Text
  filePath    String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relationships
  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])

  @@map("audit_responses")
}

model AiEvaluation {
  id             Int      @id @default(autoincrement())
  userId         Int
  overallScore   Int      @default(0)
  riskLevel      String?  @db.VarChar(20)
  summary        String?  @db.Text
  categoryScores String?  @db.Text     // JSON string of per-category AI scores
  gaps           String?  @db.Text     // JSON string of gap analysis
  recommendations String? @db.Text     // JSON string of recommendations
  fullReport     String?  @db.Text     // Full text-based report from AI
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  @@map("ai_evaluations")
}

model AuditResponseLog {
  id          Int      @id @default(autoincrement())
  responseId  Int      
  oldAnswer   Boolean
  oldComment  String?  @db.Text
  oldFilePath String?  
  updatedAt   DateTime @default(now())

  @@map("audit_response_logs")
}