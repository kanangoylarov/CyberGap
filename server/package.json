{
  "name": "server",
  "version": "1.0.0",
  "description": "Production-ready backend setup with Node.js, Express, and Prisma",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "echo \"No build step required for vanilla JS\" && exit 0",
    "start": "node src/server.js",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.21.1",
    "@supabase/supabase-js": "^2.99.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "5.21.1"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
